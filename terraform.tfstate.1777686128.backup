            "yaml_body": "\"apiVersion\": \"karpenter.sh/v1\"\n\"kind\": \"NodePool\"\n\"metadata\":\n  \"name\": \"linux-x64-largemem\"\n\"spec\":\n  \"disruption\":\n    \"consolidateAfter\": \"300s\"\n    \"consolidationPolicy\": \"WhenEmpty\"\n  \"limits\":\n    \"cpu\": \"128\"\n    \"memory\": \"512Gi\"\n  \"template\":\n    \"metadata\":\n      \"labels\":\n        \"valkey.io/pool\": \"x64-largemem\"\n    \"spec\":\n      \"nodeClassRef\":\n        \"group\": \"karpenter.k8s.aws\"\n        \"kind\": \"EC2NodeClass\"\n        \"name\": \"x64\"\n      \"requirements\":\n      - \"key\": \"kubernetes.io/arch\"\n        \"operator\": \"In\"\n        \"values\":\n        - \"amd64\"\n      - \"key\": \"karpenter.sh/capacity-type\"\n        \"operator\": \"In\"\n        \"values\":\n        - \"on-demand\"\n      - \"key\": \"node.kubernetes.io/instance-type\"\n        \"operator\": \"In\"\n        \"values\":\n        - \"m7i.4xlarge\"\n        - \"m6i.4xlarge\"\n",
            "yaml_body_parsed": "apiVersion: karpenter.sh/v1\nkind: NodePool\nmetadata:\n  name: linux-x64-largemem\nspec:\n  disruption:\n    consolidateAfter: 300s\n    consolidationPolicy: WhenEmpty\n  limits:\n    cpu: \"128\"\n    memory: 512Gi\n  template:\n    metadata:\n      labels:\n        valkey.io/pool: x64-largemem\n    spec:\n      nodeClassRef:\n        group: karpenter.k8s.aws\n        kind: EC2NodeClass\n        name: x64\n      requirements:\n      - key: kubernetes.io/arch\n        operator: In\n        values:\n        - amd64\n      - key: karpenter.sh/capacity-type\n        operator: In\n        values:\n        - on-demand\n      - key: node.kubernetes.io/instance-type\n        operator: In\n        values:\n        - m7i.4xlarge\n        - m6i.4xlarge\n",
